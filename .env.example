PORT=3000
HOST=127.0.0.1
MCP_PATH=/mcp
MCP_AUTH_TOKEN=

# Tool profile: "full" exposes all 12 tools (default).
# "minimal" exposes only the low-cost Claude-oriented set:
#   search_notes, list_notes, read_note_excerpt, read_section,
#   update_note_draft, propose_change, rename_note, move_note, create_folder.
# The overlapping high-cost tools (search, fetch, read_note) are disabled.
TOOL_PROFILE=full

# Single-target mode: point the server directly at one vault.
VAULT_REPO_ROOT=/absolute/path/to/your/obsidian-vault-clone
VAULT_POLICY_FILE=./config/vault-access-policy.example.yaml

# Multi-target mode: load a catalog of named vault targets.
VAULT_TARGETS_FILE=
VAULT_TARGET=

# Vault-manifest mode: bootstrap from a manifest stored inside the vault itself,
# e.g. /absolute/path/to/your-vault/.config/mcp/vault-target.yaml
VAULT_TARGET_MANIFEST_FILE=

GITHUB_OWNER=your-org
GITHUB_REPO=your-vault-repo
GITHUB_TOKEN=ghp_xxx
GITHUB_DEFAULT_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com

GIT_AUTHOR_NAME=Obsidian MCP Bot
GIT_AUTHOR_EMAIL=bot@example.com

MAX_CHANGE_FILES=5
MAX_TOTAL_LINE_DELTA=400
