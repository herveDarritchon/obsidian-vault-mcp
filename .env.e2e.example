PORT=3000
HOST=127.0.0.1
MCP_PATH=/mcp
MCP_AUTH_TOKEN=

# Optional multi-target mode. Set these when the server config is catalog-based.
VAULT_TARGETS_FILE=./config/vault-targets.example.yaml
VAULT_TARGET=e2e

# Optional single-target mode. Use these instead of VAULT_TARGETS_FILE/VAULT_TARGET.
VAULT_REPO_ROOT=/absolute/path/to/your/obsidian-vault-clone
VAULT_POLICY_FILE=./config/vault-access-policy.e2e.yaml

GITHUB_OWNER=your-org
GITHUB_REPO=your-vault-repo
GITHUB_TOKEN=ghp_xxx
GITHUB_API_BASE_URL=https://api.github.com

GIT_AUTHOR_NAME=Obsidian MCP Bot
GIT_AUTHOR_EMAIL=bot@example.com

MAX_CHANGE_FILES=5
MAX_TOTAL_LINE_DELTA=400

E2E_TARGET=
E2E_NOTE_PATH=02-Work/TOR2e/working/test-note.md
E2E_SEARCH_ROOT=02-Work/TOR2e/working
E2E_LIST_ROOT=02-Work/TOR2e/working
E2E_LIST_LIMIT=200
E2E_SEARCH_QUERY=test note
E2E_SECTION_PATH=README.md
E2E_SECTION_HEADING=# obsidian-mcp-e2e-vault
E2E_BLACKLISTED_PATH=Private/e2e-secret.md
E2E_BASE_BRANCH=main
E2E_BRANCH_SCOPE=e2e
E2E_BRANCH_SLUG=obsidian-vault-mcp
E2E_CLEANUP=false
E2E_SKIP_PROPOSE_CHANGE=false
